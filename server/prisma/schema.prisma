generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("AUTHOR")
  createdAt DateTime @default(now())
  address   String?
  interests String?
  phone     String?
  queries   Query[]
}

model AuthorDraft {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  step           Int      @default(0)
  form           Json
  books          Json
  qualifications Json
  extraDataState Json
  skillInput     String?
  hobbyInput     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completed      Boolean  @default(false)
}

model OtpVerification {
  email     String   @id
  otp       String
  expiresAt DateTime
}

model Author {
  id                    Int                    @id @default(autoincrement())
  name                  String
  email                 String                 @unique
  phone                 String
  bio                   String
  photoUrl              String?
  status                String                 @default("Pending")
  createdAt             DateTime               @default(now())
  whatsapp              String?
  rejectionReason       String?
  paymentScreenshot     String?
  transactionId         String?
  extraData             Json?
  qrCodeUrl             String?
  city                  String?
  facebook              String?
  instagram             String?
  penName               String?
  state                 String?
  aadharNumber          String?
  address               String?
  qualification         String?
  age                   String?
  experience            String?
  hobbies               String?
  skills                String?
  whyJoining            String?
  certificateUrl        String?
  district              String?
  dob                   String?
  hobbiesJson           Json?
  institution           String?
  pincode               String?
  qualificationsJson    Json?
  skillsJson            Json?
  subject               String?
  groupJoiningDate      DateTime?
  aggParticipatedEvents Int?
  aggEligibleEvents     Int?
  books                 Book[]
  eventAuthors          EventAuthor[]
  eventBooks            EventBook[]
  eventRegistrations    EventRegistration[]
  formResponses         FormResponse[]
  posOrders             PosOrder[]
  queries               Query[]
  donationRegistrations DonationRegistration[]
  donationLogs          DonationLog[]
  invitations           AuthorInvitation[]
}

model Query {
  id        Int      @id @default(autoincrement())
  authorId  Int?
  subject   String
  message   String
  status    String   @default("Pending")
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?
  author    Author?  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Book {
  id              Int            @id @default(autoincrement())
  title           String
  genre           String
  subGenre        String?
  synopsis        String
  pages           Int?
  mrp             Float
  coverUrl        String?
  status          String         @default("Pending")
  authorId        Int
  createdAt       DateTime       @default(now())
  overpriced      Boolean        @default(false)
  stock           Int            @default(0)
  airportStock    Int            @default(0)
  fairStock       Int            @default(0)
  rejectionReason String?
  edition         String?
  format          String?
  isbn            String?
  language        String?
  publicationDate String?
  publisher       String?
  subtitle        String?
  backCoverUrl    String?
  printFormat     String?
  purpose         String?
  author          Author         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviews         BookReview[]
  eventBooks      EventBook[]
  orderItems      OrderItem[]
  posOrderItems   PosOrderItem[]
  donationBooks   DonationBook[]
  donationLogs    DonationLog[]
  stockHistory    StockHistory[]
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id                Int         @id @default(autoincrement())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  address           String?
  amount            Float
  subtotal          Float       @default(0)
  bundleDiscount    Float       @default(0)
  deliveryCharges   Float       @default(0)
  paymentScreenshot String?
  createdAt         DateTime    @default(now())
  status            String      @default("Pending Verification")
  transactionId     String?
  customerId        Int?
  isBulk            Boolean     @default(false)
  customer          Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items             OrderItem[]
}

model OrderItem {
  id                   Int       @id @default(autoincrement())
  orderId              Int
  bookId               Int
  quantity             Int       @default(1)
  status               String    @default("Pending Verification")
  createdAt            DateTime  @default(now())
  trackingNumber       String?
  rejectionReason      String?
  deliveredAt          DateTime?
  dispatchedAt         DateTime?
  acceptedAt           DateTime?
  expectedDeliveryDate DateTime?
  autoDelivered        Boolean   @default(false)
  authorWarnedAt       DateTime?
  authorDispatchWarnedAt DateTime?
  feedbackComments     String?
  feedbackCondition    String?
  feedbackRating       Int?
  feedbackPackaging    String?
  feedbackAsExpected   String?
  feedbackBuyAgain     String?
  book                 Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order                Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model GalleryEvent {
  id          Int            @id @default(autoincrement())
  location    String
  place       String
  city        String
  date        DateTime
  duration    String
  authors     Int
  booksSold   Int
  type        String
  description String
  photoUrl    String
  createdAt   DateTime       @default(now())
  eventId     Int?           @unique
  libraryId   Int?           @unique
  library     Library?       @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  event       Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  images      GalleryImage[]
}

model GalleryImage {
  id             Int          @id @default(autoincrement())
  galleryEventId Int
  url            String
  caption        String?
  dateTaken      DateTime?
  createdAt      DateTime     @default(now())
  status         String       @default("Pending")
  galleryEvent   GalleryEvent @relation(fields: [galleryEventId], references: [id], onDelete: Cascade)
}

model Activity {
  id            Int                 @id @default(autoincrement())
  name          String
  date          String
  city          String
  charges       Float
  type          String
  status        String              @default("OPEN")
  createdAt     DateTime            @default(now())
  registrations EventRegistration[]
}

model EventRegistration {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  activityId        Int
  amount            Float
  authorId          Int
  booksIds          String
  paymentScreenshot String?
  status            String   @default("Pending Verification")
  activity          Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author            Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model FormTemplate {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  fields      Json
  createdAt   DateTime       @default(now())
  type        String         @default("Literary Events")
  responses   FormResponse[]
}

model FormResponse {
  id             Int          @id @default(autoincrement())
  formTemplateId Int
  authorId       Int
  answers        Json
  createdAt      DateTime     @default(now())
  author         Author       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
}

model BookReview {
  id                   Int      @id @default(autoincrement())
  bookId               Int
  reviewerName         String
  rating               Int
  comment              String
  writingStyleRating   Int?
  contentQualityRating Int?
  enjoyedMost          String?
  createdAt            DateTime @default(now())
  book                 Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Event {
  id                Int           @id @default(autoincrement())
  name              String
  location          String
  date              String
  dateType          String?       @default("exact")
  tentativeDate     String?
  duration          String
  status            String        @default("Upcoming")
  createdAt         DateTime      @default(now())
  broadcastStatus   String        @default("None")
  brochureUrl       String?
  description       String?
  commissionFlat    Float?
  commissionPercent Float?
  eventType         String        @default("Book Fair")
  category          String?
  feeType           String        @default("Per Author")
  registrationFee   Float         @default(0)
  bannerUrl         String?
  livePosEnabled    Boolean       @default(true)
  endTime           String?
  startTime         String?
  aggAuthors        Int?
  aggTitles         Int?
  aggSent           Int?
  aggSold           Int?
  aggRevenue        Float?
  aggEligibleAuthors Int?
  eventAuthors      EventAuthor[]
  eventBooks        EventBook[]
  galleryEvent      GalleryEvent?
  posOrders         PosOrder[]
}

model EventAuthor {
  id                 Int      @id @default(autoincrement())
  eventId            Int
  authorId           Int
  optInStatus        String   @default("Pending")
  createdAt          DateTime @default(now())
  paymentScreenshot  String?
  transactionId      String?
  manualTotalSold    Int?
  manualTotalRevenue Float?
  amountPaid         Float?
  investment         Float?   @default(0)
  paymentStatus      String?  @default("Unpaid")
  rejectionReason    String?
  author             Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event              Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventBook {
  id            Int      @id @default(autoincrement())
  eventId       Int
  bookId        Int
  authorId      Int
  listedStock   Int      @default(0)
  soldStock     Int      @default(0)
  returnedStock Int      @default(0)
  overrideMrp   Float?
  createdAt     DateTime @default(now())
  author        Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model PosOrder {
  id               Int            @id @default(autoincrement())
  authorId         Int
  eventId          Int
  totalAmount      Float
  paymentMethod    String         @default("UPI")
  createdAt        DateTime       @default(now())
  paymentReference String?
  paymentStatus    String         @default("CONFIRMED")
  saleSource       String         @default("BOOK_FAIR")
  author           Author         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event            Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items            PosOrderItem[]
}

model PosOrderItem {
  id         Int      @id @default(autoincrement())
  posOrderId Int
  bookId     Int
  quantity   Int
  price      Float
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  posOrder   PosOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
}

model Notification {
  id           Int      @id @default(autoincrement())
  message      String
  target       String   @default("ALL")
  documentUrl  String?
  documentName String?
  createdAt    DateTime @default(now())
}

model Library {
  id              Int      @id @default(autoincrement())
  name            String
  type            String // Airport Library, Public Library, etc.
  airportCode     String?
  airportName     String?
  city            String
  state           String
  country         String
  contactPerson   String
  contactNumber   String
  email           String?
  shippingAddress String
  status          String   @default("Active") // Active / Inactive
  bannerUrl       String?
  createdAt       DateTime @default(now())

  announcements DonationAnnouncement[]
  logs          DonationLog[]
  galleryEvent  GalleryEvent?
}

model DonationAnnouncement {
  id                     Int      @id @default(autoincrement())
  title                  String
  description            String
  libraryId              Int
  library                Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  eventDate              String?
  announcementDate       String
  registrationStartDate  String
  registrationEndDate    String
  expectedCollectionDate String
  expectedDispatchDate   String
  collectionPoint        String
  dispatchAddress        String
  contactPerson          String
  contactNumber          String
  feeType                String   @default("Free")
  feeAmount              Int?
  additionalInstructions String?
  visibility             String   @default("Draft") // Draft, Published, Closed
  createdAt              DateTime @default(now())

  registrations DonationRegistration[]
}

model DonationRegistration {
  id                 Int    @id @default(autoincrement())
  announcementId     Int
  authorId           Int
  status             String @default("Registered") // Registered, Approved, Rejected, Changes Requested
  verificationStatus String @default("Pending")
  dispatchStatus     String @default("Pending")
  receivedStatus     String @default("Pending")

  feePaid           Int?
  paymentStatus     String? @default("Pending") // Pending, Completed, Failed
  paymentScreenshot String?
  transactionId     String?

  dispatchDate    String?
  courierPartner  String?
  trackingNumber  String?
  collectionPoint String?
  packedBy        String?

  receivedDate        String?
  receivedBy          String?
  libraryConfirmation Boolean @default(false)
  proofImageUrl       String?
  remarks             String?

  useGlobalOverride   Boolean @default(false)
  globalBooksDonated  Int?    @default(0)
  globalDonationValue Float?  @default(0)
  globalRemarks       String?
  broadcastStatus     String  @default("Draft")

  createdAt DateTime @default(now())

  announcement DonationAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  author       Author               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  books        DonationBook[]
}

model DonationBook {
  id                  Int      @id @default(autoincrement())
  registrationId      Int
  bookId              Int
  quantityDonated     Int
  qtyCollected        Int      @default(0)
  qtyDispatched       Int      @default(0)
  qtyReceived         Int      @default(0)
  libraryConfirmation String   @default("Pending")
  remarks             String?
  createdAt           DateTime @default(now())

  registration DonationRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  book         Book                 @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model DonationLog {
  id           Int      @id @default(autoincrement())
  date         DateTime @default(now())
  libraryId    Int
  authorId     Int
  bookId       Int
  quantity     Int
  dispatchDate String?
  deliveryDate String?
  status       String
  remarks      String?

  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  author  Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  book    Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model StockHistory {
  id           Int      @id @default(autoincrement())
  bookId       Int
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  changeQty    Int
  lastStock    Int
  currentStock Int
  status       String   @default("Approved")
  updatedAt    DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}

model AuthorInvitation {
  id Int @id @default(autoincrement())

  // Customer details
  customerName     String
  organizationName String?
  customerEmail    String
  customerPhone    String

  // Event details
  eventTitle       String
  eventDescription String
  reasonForInvite  String
  eventType        String
  eventDate        String
  eventTime        String?
  venue            String
  expectedAudience String?
  additionalNotes  String?

  // Author being invited
  authorId Int
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Admin workflow
  status       String  @default("Pending")
  adminRemarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
